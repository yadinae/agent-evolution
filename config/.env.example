# Agent Evolution Configuration Example
# Copy this file to .env and fill in your values

# ============================================
# Feishu (Lark) Notification Configuration
# ============================================
FEISHU_APP_ID=cli_a90b5d6d8e395bc9
FEISHU_APP_SECRET=your_app_secret_here
FEISHU_CHANNEL_ID=ou_608260b868adf690d70569214d83cfda

# ============================================
# Database Configuration
# ============================================
TASK_MONITORING_DB=data/task-monitoring.db
SKILL_QUALITY_DB=data/skill-quality.db
SKILL_ANALYTICS_DB=data/skill-analytics.db

# ============================================
# Logging Configuration
# ============================================
LOG_LEVEL=INFO
LOG_FILE=logs/evolution.log
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# ============================================
# Performance Thresholds
# ============================================
# Success rate threshold (0.0 - 1.0)
MIN_SUCCESS_RATE=0.8

# Maximum average duration (seconds)
MAX_AVG_DURATION=60.0

# Health score thresholds (0-100)
CRITICAL_HEALTH_SCORE=40
WARNING_HEALTH_SCORE=60

# ============================================
# Alert Configuration
# ============================================
# Enable/disable alerts
ENABLE_ALERTS=true

# Alert channels (comma-separated: feishu,email,slack)
ALERT_CHANNELS=feishu

# Error rate threshold for alerts (0.0 - 1.0)
ERROR_RATE_THRESHOLD=0.1

# ============================================
# Evolution Engine Configuration
# ============================================
# Maximum recommendations to generate
MAX_RECOMMENDATIONS=10

# Minimum confidence score for recommendations (0.0 - 1.0)
MIN_CONFIDENCE_SCORE=0.6

# Enable automatic implementation (experimental)
AUTO_IMPLEMENT=false

# ============================================
# Backup Configuration
# ============================================
ENABLE_BACKUP=true
BACKUP_DIR=backups
BACKUP_RETENTION_DAYS=30
BACKUP_RETENTION_COUNT=10
